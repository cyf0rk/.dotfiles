#!/bin/bash
set -euo pipefail

# Set variables for Obsidian to Hugo copy
sourcePath="$HOME/vaults/personal/blog"
destinationPath="$HOME/work/marijan.dev"

# Change to site directory
cd "$destinationPath"

# Check for required commands
for cmd in git rsync hugo; do
    if ! command -v $cmd &> /dev/null; then
        echo "$cmd is not installed or not in PATH."
        exit 1
    fi
done

# Guard: a running hugo server rewrites public/ with localhost URLs
# (renders to disk since hugo 0.123) and would race the build below
if lsof -ti :1313 >/dev/null 2>&1; then
    echo "hugo server is running (port 1313) — stop it first, it overwrites public/ with localhost URLs."
    exit 1
fi

# Step 1: Sync content from Obsidian to Hugo content folder using rsync
echo "Syncing content from Obsidian..."

if [ ! -d "$sourcePath/posts" ]; then
    echo "Source path does not exist: $sourcePath/posts"
    exit 1
fi

# Vault blog/ is the full source of truth for content/; images/ is the
# attachment folder consumed by sync-images, not a content section
rsync -av --delete --exclude 'images/' "$sourcePath/" "$destinationPath/content/"

# Step 2: Process Markdown files with script to handle image links
echo "Processing image links in Markdown files..."
if ! sync-images; then
    echo "Failed to process image links."
    exit 1
fi

# Step 3: Build the Hugo site
echo "Building the Hugo site..."
if ! hugo --cleanDestinationDir; then
    echo "Hugo build failed."
    exit 1
fi

# Step 4: Add changes to Git
echo "Staging changes for Git..."
if git diff --quiet && git diff --cached --quiet; then
    echo "No changes to stage."
else
    git add .
fi

# Step 5: Commit changes with a dynamic message
commit_message="New Blog Post on $(date +'%Y-%m-%d %H:%M:%S')"
if git diff --cached --quiet; then
    echo "No changes to commit."
else
    echo "Committing changes..."
    git commit -m "$commit_message"
fi

# Step 6: Push all changes to the main branch
echo "Deploying to GitHub Main..."
if ! git push origin main; then
    echo "Failed to push to main branch."
    exit 1
fi

# Step 7: Push the public folder to the host branch using subtree split and force push
echo "Deploying to host..."
if git branch --list | grep -q 'host-deploy'; then
    git branch -D host-deploy
fi

if ! git subtree split --prefix public -b host-deploy; then
    echo "Subtree split failed."
    exit 1
fi

if ! git push origin host-deploy:host-deploy --force; then
    echo "Failed to push to host branch."
    git branch -D host-deploy
    exit 1
fi

git branch -D host-deploy

echo "All done! Site synced, processed, committed, built, and deployed."
